# 追影 - 环境变量配置
# 请复制此文件为 .env 并修改配置

# ============ 数据库配置 ============
# PostgreSQL 连接地址（容器内部使用）
DATABASE_URL=postgresql://zhuiying:zhuiying_secret_2024@postgres:5432/zhuiying

# 如果需要外部连接数据库，使用以下地址
# DATABASE_URL=postgresql://zhuiying:zhuiying_secret_2024@host.docker.internal:5433/zhuiying

# ============ 系统配置 ============
# 服务端口
DEPLOY_RUN_PORT=35588

# 运行环境
COZE_PROJECT_ENV=PROD

# 系统登录密码（请修改！）
SYSTEM_PASSWORD=admin123

# ============ TMDB API ============
# TMDB API Key（从 https://www.themoviedb.org/settings/api 获取）
TMDB_API_KEY=your_tmdb_api_key_here

# ============ 可选配置 ============
# 禁用认证（仅开发环境使用）
# DISABLE_AUTH=true

# 代理配置（如需访问TMDB）
# HTTPS_PROXY=http://127.0.0.1:7890

# Node.js 内存限制
NODE_OPTIONS=--max-old-space-size=2048
